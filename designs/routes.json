{
    "routes": [
        {
            "path": "login",
            "component": "LoginpageComponent"
        },
        {
            "path": "''",
            "redirectTo": "login",
            "pathMatch": "full",
            "default": true
        },
        {
            "path": "home",
            "component": "HomepageComponent"
        },
        {
            "path": "**",
            "component": "PageNotFoundComponent"
        }
    ]
}
