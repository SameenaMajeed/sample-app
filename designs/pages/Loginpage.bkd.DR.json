          "4a23e7c9-e140-0bd7-2f13-dcfcca6120bb": {
            "paletteKey": "html-editor",
            "parentEditorKey": "92e68182-0daa-2b16-6417-9d42c3dd0d6a",
            "isAdvancedChildComponent": true,
            "commentid": null,
            "designerReference": [
              {
                "_key": "style",
                "_value": "",
                "_type": "kv",
                "_attrDef": "p"
              },
              {
                "_key": "class",
                "_value": "",
                "_type": "dav",
                "_attrDef": "p"
              },
              {
                "_key": "html",
                "_value": "<div class=\"card\">\n  <h2>Welcome Back</h2>\n  <p>Don&apos;t have an account? <b>Sign up</b></p>\n  \n  <form [formGroup]=\"loginForm\" (ngSubmit)=\"onSubmit()\">\n    <div class=\"form-group\">\n      <label [class.error-label]=\"loginForm.get('email').invalid && loginForm.get('email').touched\">Email Address</label>\n      <input type=\"email\" class=\"input\" placeholder=\"name@company.com\" formControlName=\"email\"\n             [class.error-border]=\"loginForm.get('email').invalid && loginForm.get('email').touched\">\n      <small class=\"error-msg\" *ngIf=\"loginForm.get('email').invalid && loginForm.get('email').touched\">\n        Please enter a valid email address.\n      </small>\n    </div>\n\n    <div class=\"form-group\">\n      <label [class.error-label]=\"loginForm.get('password').invalid && loginForm.get('password').touched\">Password</label>\n      <input type=\"password\" class=\"input\" placeholder=\"••••••••\" formControlName=\"password\"\n             [class.error-border]=\"loginForm.get('password').invalid && loginForm.get('password').touched\">\n      <small class=\"error-msg\" *ngIf=\"loginForm.get('password').invalid && loginForm.get('password').touched\">\n        Password must be at least 6 characters.\n      </small>\n    </div>\n\n    <button type=\"submit\" class=\"button\" [disabled]=\"loginForm.invalid && loginForm.touched\">Sign In</button>\n  </form>\n\n  <div class=\"divider\">OR</div>\n\n  <div class=\"socials\">\n    <button aria-label=\"Sign in with Apple\" type=\"button\"></button>\n    <button aria-label=\"Sign in with Google\" type=\"button\">G</button>\n    <button aria-label=\"Sign in with X\" type=\"button\">X</button>\n  </div>\n</div>",
                "_type": "a",
                "_attrDef": "p"
              }
            ]
          }
        }
      }
